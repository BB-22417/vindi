# Railway Production Environment Variables
# Set these in the Railway Dashboard under your project's variables

# Application
NODE_ENV=production
PORT=4000

# Database (Railway PostgreSQL plugin will set DATABASE_URL automatically)
DATABASE_URL=postgresql://user:password@host:5432/vindi

# Auth
JWT_SECRET=your-super-secret-jwt-key
JWT_EXPIRES_IN=7d

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Payments
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret

# Email
RESEND_API_KEY=your-resend-api-key

# Frontend
FRONTEND_URL=https://vindi.vercel.app
